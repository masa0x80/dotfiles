#!/bin/zsh

zshenv_cache="$XDG_CACHE_HOME/zshenv-cache.zsh"
zshrc_cache="$XDG_CACHE_HOME/zshrc-cache.zsh"
zshrc_defer_cache="$XDG_CACHE_HOME/zshrc-defer-cache.zsh"

# .zshenv cache
echo -n > $zshenv_cache

# homebrew
# no_global_rcsを設定しているので `path_helper` 呼び出しは不要
brew shellenv | grep -v 'path_helper' >> $zshenv_cache
source $zshenv_cache

echo "export AGE_IDENTITY=\"$HOME/.ssh/age\"" >> $zshenv_cache
echo "export AGE_RECIPIENT=\"$HOME/.ssh/age.pub\"" >> $zshenv_cache
echo "export PASSAGE_IDENTITIES_FILE=\"$HOME/.ssh/key\"" >> $zshenv_cache
echo "export PASSAGE_RECIPIENTS_FILE=\"$HOME/.ssh/key.pub\"" >> $zshenv_cache
echo "export PASSAGE_AGE=\"$HOMEBREW_PREFIX/bin/rage\"" >> $zshenv_cache

# Generate .zshrc
echo -n > $zshrc_cache

(( ${+commands[sheldon]} )) && sheldon source >> $zshrc_cache
(( ${+commands[starship]} )) && starship init zsh >> $zshrc_cache

echo -n > $zshrc_defer_cache
(( ${+commands[mise]} )) && mise activate zsh | sed '/^_mise_hook$/d' >> $zshrc_defer_cache
(( ${+commands[fzf]} )) && fzf --zsh >> $zshrc_defer_cache
(( ${+commands[direnv]} )) && direnv hook zsh >> $zshrc_defer_cache
(( ${+commands[zabrze]} )) && zabrze init --bind-keys >> $zshrc_defer_cache
echo "zsh-defer source \"$zshrc_defer_cache\"" >> $zshrc_cache

# zcompile
for file (
  $zshenv_cache
  $zshrc_cache
  $zshrc_defer_cache
  $HOME/.zshenv(N)
  $HOME/.zshrc(N)
  $HOME/.config.local/zsh/zshenv(N)
  $HOME/.zshenv.local(N)
) zcompile $file
